object MainForm: TMainForm
  Left = 0
  Top = 0
  Caption = 'Hello FMX App'
  ClientHeight = 200
  ClientWidth = 350
  Position = ScreenCenter
  FormFactor.Width = 320
  FormFactor.Height = 480
  FormFactor.Devices = [Desktop]
  object lblTitle: TLabel
    Position.X = 20
    Position.Y = 20
    Width = 200
    Height = 17
    Text = 'Enter your name:'
  end
  object edtName: TEdit
    Position.X = 20
    Position.Y = 50
    Width = 300
    Height = 30
    TabOrder = 0
    Text = ''
  end
  object btnHello: TButton
    Position.X = 20
    Position.Y = 100
    Width = 150
    Height = 40
    Text = 'Say Hello'
    TabOrder = 1
    OnClick = btnHelloClick
  end
end
